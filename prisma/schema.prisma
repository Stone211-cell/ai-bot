// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String        @id @default(cuid())
  discordId     String        @unique @map("discord_id")
  username      String
  nickname      String?       // ชื่อเล่นภาษาไทยของผู้ใช้งาน
  discriminator String        @default("0")
  avatarUrl            String?       @map("avatar_url")
  isBot                Boolean       @default(false) @map("is_bot")
  summary              String?       @db.Text
  msgCountSinceSummary Int           @default(0) @map("msg_count_since_summary")
  affinity             Int           @default(0) // -100 to 100
  relationshipStatus   String?       @map("relationship_status")
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @updatedAt @map("updated_at")
  chatMessages  ChatMessage[]

  @@map("users")
}

model ChatMessage {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  channelId String   @map("channel_id")
  guildId   String?  @map("guild_id")
  role      String   // "user" | "assistant"
  content   String   @db.Text
  tokens    Int?
  model     String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([channelId])
  @@index([createdAt])
  @@map("chat_messages")
}

model GlobalKnowledge {
  id        String   @id @default(cuid())
  topic     String
  fact      String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  @@map("global_knowledge")
}

model Category {
  id         String      @id @default(cuid())
  name       String      @unique
  type       String      // "ARTICLE" หรือ "PORTFOLIO"
  createdAt  DateTime    @default(now())
  articles   Article[]
  portfolios Portfolio[]
}

model Article {
  id          String    @id @default(cuid())
  title       String
  excerpt     String
  content     String    @db.Text
  image       String
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  author      String    @default("ช่างมิลการประปา")
  slug        String    @unique
  published   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Portfolio {
  id          String    @id @default(cuid())
  title       String
  description String?
  image       String
  videoUrl    String?
  postUrl     String?
  mediaType   String    @default("image") // "image" หรือ "video"
  categoryId  String?
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  featured    Boolean   @default(false)
  displayOrder Int       @default(1000)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}
